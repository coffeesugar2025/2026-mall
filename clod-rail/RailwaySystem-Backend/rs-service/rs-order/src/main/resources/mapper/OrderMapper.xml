<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.rs.mapper.OrderMapper">

    <resultMap id="OrderDetailResultMap" type="com.rs.model.dto.response.OrderDetailResDTO">
        <id property="orderId" column="order_id"/>
        <result property="status" column="status"/>
        <result property="totalAmount" column="amount"/>
        <result property="ticketId" column="ticket_id"/>
        <result property="voucherId" column="voucher_id"/>
        <result property="createTime" column="create_time"/>
        <result property="payTime" column="pay_time"/>
        <result property="expireTime" column="expire_time"/>
    </resultMap>

    <resultMap id="PermissionsResultMap" type="com.rs.model.domain.Permissions">
        <result property="canPay" column="can_pay"/>
        <result property="canCancel" column="can_cancel"/>
        <result property="canChange" column="can_change"/>
    </resultMap>
    
    <resultMap id="OrderDetailResDTO" type="com.rs.model.dto.response.OrderDetailResDTO">
        <id property="orderId" column="order_id"/>
        <result property="status" column="status"/>
        <result property="totalAmount" column="amount"/>
        <result property="ticketId" column="ticket_id"/>
        <result property="voucherId" column="voucher_id"/>
        <result property="createTime" column="create_time"/>
        <result property="payTime" column="pay_time"/>
        <result property="expireTime" column="expire_time"/>
    </resultMap>

    <insert id="createOrder">
        INSERT INTO `order`
        <trim prefix="(" suffix=")" suffixOverrides=",">
            order_id,
            user_id,
            ticket_id,
            amount,
            <if test="status != null">status,</if>
            <if test="paymentMethod != null">payment_method,</if>
            <if test="couponId != null">coupon_id,</if>
            <if test="expireTime != null">expire_time,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
        </trim>
        <trim prefix="VALUES (" suffix=")" suffixOverrides=",">
            #{orderId},
            #{userId},
            #{ticketId},
            #{amount},
            <if test="status != null">#{status},</if>
            <if test="paymentMethod != null">#{paymentMethod},</if>
            <if test="couponId != null">#{couponId},</if>
            <if test="expireTime != null">#{expireTime},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
        </trim>
    </insert>

    <insert id="createOrderSeat">
        insert into order_seat (order_id, seat_id, passenger_id)
            value (#{orderId}, #{seatId}, #{passengerId})
    </insert>

    <update id="updateAliPayStatus">
        update `order`
        set status = 1,
            payment_method = 0,
            pay_time = now()
        where order_id = #{orderId}
    </update>

    <update id="updateStatus">
        update `order`
        set status = #{status},
            update_time = now()
        where order_id = #{orderId}
          and status = #{expectStatus}
    </update>

    <select id="queryDetail" resultMap="OrderDetailResultMap">
        select order_id,
               status,
               amount,
               ticket_id,
               voucher_id,
               create_time,
               pay_time,
               expire_time
        from `order`
        where order_id = #{orderId}
    </select>

    <select id="queryPassengers" resultType="java.lang.Long">
        select passenger_id
        from order_seat
        where order_id = #{orderId}
    </select>

    <select id="queryPermission" resultMap="PermissionsResultMap">
        SELECT
            IF(status = 0, 1, 0) AS can_pay,
            IF(status &lt; 2, 1, 0) AS can_cancel,
            IF(has_change = 0, 1, 0) AS can_change
        FROM `order`
        WHERE order_id = #{orderId}
    </select>

    <select id="queryByOrderId" resultType="com.rs.model.order.Order">
        select *
        from `order`
        where order_id = #{orderId}
    </select>
    <select id="queryOrders" resultMap="OrderDetailResDTO">
        select order_id, status, amount, ticket_id, voucher_id, create_time, pay_time, expire_time
        from `order`
        <where>
            user_id = #{userId}
            <if test="status != null">
                and status = #{status}
            </if>
            <if test="orderId != null">
                and order_id = #{orderId}
            </if>
        </where>
    </select>

    <select id="findByUserId" resultType="com.rs.model.order.Order">
        select *
        from `order`
        where user_id = #{userId}
        <if test="status != null">
            and status = #{status}
        </if>
        <if test="orderId != null">
            and order_id = #{orderId}
        </if>
        order by create_time desc
    </select>

    <select id="queryById" resultType="com.rs.model.order.Order">
        select *
        from `order`
        where id = #{id}
    </select>
    <select id="querySeat" resultType="java.lang.String">
        select seat_id
        from order_seat
        where order_id = #{orderId}
    </select>

    <select id="querySeatIdByPassenger" resultType="java.lang.Long">
        select seat_id
        from order_seat
        where order_id = #{orderId}
          and passenger_id = #{passengerId}
        limit 1
    </select>

    <select id="findRecent" resultType="com.rs.model.order.Order">
        select *
        from `order`
        order by create_time desc
        limit #{limit}
    </select>

    <select id="findByCreateTimeRange" resultType="com.rs.model.order.Order">
        select *
        from `order`
        where create_time &gt;= #{startTime}
          and create_time &lt; #{endTime}
    </select>

    <select id="findAdminPage" resultType="com.rs.model.order.Order">
        select *
        from `order`
        <where>
            <if test="orderId != null and orderId != ''">
                and order_id = #{orderId}
            </if>
            <if test="status != null">
                and status = #{status}
            </if>
            <if test="userId != null">
                and user_id = #{userId}
            </if>
            <if test="startTime != null">
                and create_time &gt;= #{startTime}
            </if>
            <if test="endTime != null">
                and create_time &lt; #{endTime}
            </if>
        </where>
        order by create_time desc
    </select>

    <select id="findExpiredUnpaidOrderIds" resultType="java.lang.String">
        select order_id
        from `order`
        where status = 0
          and expire_time is not null
          and expire_time &lt; #{now}
        order by expire_time asc
        limit #{limit}
    </select>

    <update id="markOrdersExpired">
        update `order`
        set status = #{expiredStatus},
            update_time = now()
        where status = 0
          and order_id in
        <foreach collection="orderIds" item="id" open="(" close=")" separator=",">
            #{id}
        </foreach>
    </update>

    <select id="findOrderIdsByIdsAndStatus" resultType="java.lang.String">
        select order_id
        from `order`
        where status = #{status}
          and order_id in
        <foreach collection="orderIds" item="id" open="(" close=")" separator=",">
            #{id}
        </foreach>
    </select>

</mapper>
