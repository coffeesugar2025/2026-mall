<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.rs.mapper.MallOrderMapper">

    <!-- 结果映射 -->
    <resultMap id="MallOrderResultMap" type="com.rs.model.mall.MallOrder">
        <id property="id" column="id"/>
        <result property="orderNumber" column="order_number"/>
        <result property="userId" column="user_id"/>
        <result property="itemId" column="item_id"/>
        <result property="itemName" column="item_name"/>
        <result property="itemImage" column="item_image"/>
        <result property="quantity" column="quantity"/>
        <result property="unitPrice" column="unit_price"/>
        <result property="totalPoints" column="total_points"/>
        <result property="recipientName" column="recipient_name"/>
        <result property="recipientPhone" column="recipient_phone"/>
        <result property="recipientAddress" column="recipient_address"/>
        <result property="status" column="status"/>
        <result property="shipTime" column="ship_time"/>
        <result property="completeTime" column="complete_time"/>
        <result property="cancelTime" column="cancel_time"/>
        <result property="remark" column="remark"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
        <result property="createBy" column="create_by"/>
        <result property="updateBy" column="update_by"/>
    </resultMap>

    <!-- 创建订单 -->
    <insert id="createOrder" parameterType="com.rs.model.mall.MallOrder">
        INSERT INTO mall_order (
            order_number,
            user_id,
            item_id,
            item_name,
            item_image,
            quantity,
            unit_price,
            total_points,
            recipient_name,
            recipient_phone,
            recipient_address,
            status,
            remark,
            create_time,
            update_time,
            create_by,
            update_by
        ) VALUES (
            #{orderNumber},
            #{userId},
            #{itemId},
            #{itemName},
            #{itemImage},
            #{quantity},
            #{unitPrice},
            #{totalPoints},
            #{recipientName},
            #{recipientPhone},
            #{recipientAddress},
            #{status},
            #{remark},
            #{createTime},
            #{updateTime},
            #{createBy},
            #{updateBy}
        )
    </insert>

    <!-- 根据订单号查询订单 -->
    <select id="findByOrderNumber" resultMap="MallOrderResultMap">
        SELECT * FROM mall_order
        WHERE order_number = #{orderNumber}
    </select>

    <!-- 根据用户ID查询订单列表 -->
    <select id="findByUserId" resultMap="MallOrderResultMap">
        SELECT * FROM mall_order
        WHERE user_id = #{userId}
        ORDER BY create_time DESC
    </select>

    <!-- 更新订单状态 -->
    <update id="updateStatus">
        UPDATE mall_order
        SET status = #{status},
            update_time = NOW()
        WHERE order_number = #{orderNumber}
    </update>

    <update id="updateShip">
        UPDATE mall_order
        SET status = #{status},
            ship_time = NOW(),
            update_time = NOW()
        WHERE order_number = #{orderNumber}
          AND status = #{expectStatus}
    </update>

    <!-- 分页查询用户商城订单 -->
    <select id="queryUserOrders" resultMap="MallOrderResultMap">
        SELECT * FROM mall_order
        WHERE user_id = #{userId}
        <if test="status != null">
            AND status = #{status}
        </if>
        ORDER BY create_time DESC
    </select>

    <select id="adminPage" resultMap="MallOrderResultMap">
        SELECT * FROM mall_order
        <where>
            <if test="orderNumber != null and orderNumber != ''">
                AND order_number = #{orderNumber}
            </if>
            <if test="userId != null">
                AND user_id = #{userId}
            </if>
            <if test="status != null">
                AND status = #{status}
            </if>
        </where>
        ORDER BY create_time DESC
    </select>

</mapper>
