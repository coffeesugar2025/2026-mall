<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.rs.mapper.SessionMapper">

    <resultMap id="BaseResultMap" type="com.rs.model.assistant.Memory">
        <id column="id" property="id"/>
        <result column="session_id" property="sessionId"/>
        <result column="content" property="content"/>
    </resultMap>

    <!-- 获取用户的所有会话列表 -->
    <select id="listSessionsByUserId" resultMap="BaseResultMap">
        SELECT id, session_id, content
        FROM memory
        WHERE session_id LIKE CONCAT(#{userId}, '_%')
        ORDER BY id DESC
    </select>

    <!-- 根据会话ID获取会话详情 -->
    <select id="getSessionById" resultMap="BaseResultMap">
        SELECT id, session_id, content
        FROM memory
        WHERE session_id = #{sessionId}
    </select>

    <!-- 创建新会话 -->
    <insert id="createSession" parameterType="com.rs.model.assistant.Memory">
        INSERT INTO memory (session_id, content)
        VALUES (#{sessionId}, #{content})
    </insert>

    <!-- 删除会话 -->
    <delete id="deleteSession">
        DELETE FROM memory
        WHERE session_id = #{sessionId}
          AND session_id LIKE CONCAT(#{userId}, '_%')
    </delete>

    <!-- 更新会话内容 -->
    <update id="updateSessionContent">
        UPDATE memory
        SET content = #{content}
        WHERE session_id = #{sessionId}
    </update>

</mapper>

