        {
          "value": "20",
          "description": "中型应用连接池大小"
        },
        {
          "value": "50",
          "description": "大型应用连接池大小"
        },
        {
          "value": "100",
          "description": "高并发应用连接池大小"
        }
      ]
    },
    {
      "name": "rs.mysql.hikari.minimum-idle",
      "values": [
        {
          "value": "5",
          "description": "最小空闲连接数（推荐）"
        },
        {
          "value": "10",
          "description": "中等空闲连接数"
        },
        {
          "value": "20",
          "description": "较高空闲连接数"
        }
      ]
    },
    {
      "name": "rs.mysql.db-name",
      "values": [
        {
          "value": "rs-order",
          "description": "订单服务数据库"
        },
        {
          "value": "rs-user",
          "description": "用户服务数据库"
        },
        {
          "value": "rs-ticket",
          "description": "票务服务数据库"
        },
        {
          "value": "rs-payment",
          "description": "支付服务数据库"
        }
      ]
    }
  ]
}