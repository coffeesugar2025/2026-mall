{
  "groups": [
    {
      "name": "rs.redis",
      "type": "com.rs.properties.RedisProperties",
      "sourceType": "com.rs.properties.RedisProperties"
    },
    {
      "name": "rs.redis.pool",
      "type": "com.rs.properties.RedisProperties.Pool",
      "sourceType": "com.rs.properties.RedisProperties",
      "description": "Redis 连接池配置"
    }
  ],
  "properties": [
    {
      "name": "rs.redis.host",
      "type": "java.lang.String",
      "description": "Redis 服务器主机地址",
      "defaultValue": "localhost"
    },
    {
      "name": "rs.redis.port",
      "type": "java.lang.Integer",
      "description": "Redis 服务器端口",
      "defaultValue": 6379
    },
    {
      "name": "rs.redis.password",
      "type": "java.lang.String",
      "description": "Redis 认证密码",
      "defaultValue": ""
    },
    {
      "name": "rs.redis.timeout",
      "type": "java.lang.Integer",
      "description": "Redis 命令超时时间（毫秒）",
      "defaultValue": 2000
    },
    {
      "name": "rs.redis.database",
      "type": "java.lang.Integer",
      "description": "Redis 数据库索引（0-15）",
      "defaultValue": 0
    },
    {
      "name": "rs.redis.pool.max-active",
      "type": "java.lang.Integer",
      "description": "连接池最大连接数（负值表示无限制）",
      "defaultValue": 8
    },
    {
      "name": "rs.redis.pool.max-idle",
      "type": "java.lang.Integer",
      "description": "连接池最大空闲连接数",
      "defaultValue": 8
    },
    {
      "name": "rs.redis.pool.min-idle",
      "type": "java.lang.Integer",
      "description": "连接池最小空闲连接数",
      "defaultValue": 0
    },
    {
      "name": "rs.redis.pool.max-wait",
      "type": "java.lang.Integer",
      "description": "获取连接时的最大等待时间（毫秒，-1 表示无限等待）",
      "defaultValue": -1
    }
  ],
  "hints": []
}